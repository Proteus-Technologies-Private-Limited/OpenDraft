{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OpenDraft",
  "version": "0.6.6",
  "identifier": "com.proteus.opendraft",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && VITE_API_BASE=http://localhost:18321/api npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "url": "splash.html",
        "title": "OpenDraft",
        "width": 480,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": true
      },
      {
        "label": "main",
        "url": "index.html",
        "title": "OpenDraft",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/opendraft-api"
    ],
    "iOS": {
      "minimumSystemVersion": "15.0"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "category": "public.app-category.productivity"
  },
  "plugins": {}
}
