# Only frontend/ and backend/ are needed for the Docker build.
# Exclude everything else.

# Tauri / native builds (20 GB+)
src-tauri/

# Python venv (rebuilt in container)
venv/

# Node dependencies (rebuilt in container)
frontend/node_modules
collab-server/

# Build artifacts
frontend/dist
backend/static
backend/dist
backend/build
backend/__pycache__
build/
dist/

# Data & env
backend/data
.env
*.env

# Git & IDE
.git
.github
.vscode
.claude

# Large assets not needed at runtime
images/
certificates/
fastlane/
user-manual/
landing/

# Misc
*.md
Promotion
docs
test-script
*.dmg
*.app
*.pkg
*.ipa
*.aab
*.apk
