# ── DuckDNS subdomains (or any domain pointed at this VPS's public IP) ──
DEMO_HOST=opendraft.duckdns.org
COLLAB_HOST=opendraft-collab.duckdns.org

# Email for Let's Encrypt expiry notices
ACME_EMAIL=you@example.com

# Collab server secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-hex-string

# CORS origins the collab server will accept (comma-separated, no spaces)
CORS_ORIGINS=https://opendraft.duckdns.org,http://localhost:5173,tauri://localhost,https://tauri.localhost

# ─────────────────────────────────────────────────────────────────────────────
# Combined-image mode only (./deploy.sh --combined). Ignored by the default
# per-service mode. The image lives at:
#   ghcr.io/proteus-technologies-private-limited/opendraft-combined:<tag>
# Pin a specific version for predictable rollbacks; "latest" tracks the most
# recent release tag pushed by .github/workflows/docker-publish.yml.
# OPENDRAFT_VERSION=0.16.2

# Optional SMTP for transactional email (verification links). Leave SMTP_HOST
# unset and the collab server auto-verifies new sign-ups instead.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Optional one-time demo user seeded on first boot. Idempotent — existing
# users are not touched. Leave SEED_DEMO_USER unset to disable.
# SEED_DEMO_USER=true
# SEED_DEMO_USER_EMAIL=demo@opendraft.local
# SEED_DEMO_USER_PASSWORD=
# SEED_DEMO_USER_NAME=Demo User
