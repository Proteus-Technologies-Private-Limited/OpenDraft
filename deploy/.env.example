# ── DuckDNS subdomains (or any domain pointed at this VPS's public IP) ──
DEMO_HOST=opendraft-demo.duckdns.org
COLLAB_HOST=opendraft-collab.duckdns.org

# Email for Let's Encrypt expiry notices
ACME_EMAIL=you@example.com

# Collab server secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-hex-string

# CORS origins the collab server will accept (comma-separated, no spaces)
CORS_ORIGINS=https://opendraft-demo.duckdns.org,http://localhost:5173,tauri://localhost,https://tauri.localhost
