# Template for deploy/combined.env — copy and fill in. The real file is gitignored.
#   cp deploy/combined.env.example deploy/combined.env
#   docker run --env-file deploy/combined.env -p 18080:8080 -p 18081:8081 opendraft-combined

# REQUIRED — secret used to sign JWT access/refresh tokens.
JWT_SECRET=change-me

# OPTIONAL — SMTP credentials for transactional email (verification, password
# reset). Without these, the collab server logs verification codes to stdout
# and email_verification stays disabled.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# OPTIONAL — seed a single demo user on first boot. Idempotent: skipped if the
# email already exists. Leave SEED_DEMO_USER unset to disable.
SEED_DEMO_USER=false
SEED_DEMO_USER_EMAIL=demo@opendraft.local
SEED_DEMO_USER_PASSWORD=
SEED_DEMO_USER_NAME=Demo User
