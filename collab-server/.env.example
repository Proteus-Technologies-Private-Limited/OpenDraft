# OpenDraft Collaboration Server Configuration

# Server port (both WebSocket and REST API share this port)
PORT=4000

# Backend API URL (for invite token validation)
BACKEND_URL=http://localhost:8008/api

# JWT secret key (REQUIRED in production, auto-generated in development)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT token expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt rounds for password hashing
BCRYPT_ROUNDS=12

# Data directory (Yjs documents + SQLite database if using sqlite)
DATA_DIR=./data

# ── Database ──
# Type: "sqlite" (default, file-based) or "postgresql" (recommended for 50+ users)
DB_TYPE=sqlite

# PostgreSQL settings (only used when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opendraft_collab
DB_USER=opendraft
DB_PASSWORD=

# ── Document eviction ──
# Idle documents are unloaded from memory after this many minutes (0 = disabled)
DOC_IDLE_TIMEOUT_MINUTES=30

# ── WebSocket connection limits ──
# Maximum concurrent WebSocket connections per IP address (0 = unlimited)
WS_MAX_CONNECTIONS_PER_IP=50

# Maximum concurrent WebSocket connections per user (0 = unlimited)
WS_MAX_CONNECTIONS_PER_USER=10

# TLS/SSL (optional - enables wss:// and https://)
# Set both to enable TLS. Leave empty for ws:// (suitable for local networks).
TLS_CERT=
TLS_KEY=

# Google OAuth (optional - enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP for email verification (optional - if not set, codes are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@opendraft.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,tauri://localhost,https://tauri.localhost
